# ==============================================================================
#  CAMRIE Fargate image (GPU-enabled)
#  CUDA 12.6 + Python 3.11 + Julia 1.11 + KomaMRI precompiled
# ==============================================================================
FROM nvidia/cuda:12.6.3-runtime-ubuntu22.04

WORKDIR /app

# ── OS deps + Python 3.11 ────────────────────────────────────────────────────
ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        software-properties-common \
 && add-apt-repository ppa:deadsnakes/ppa \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev python3-pip \
        git ca-certificates wget curl libgomp1 \
 && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
 && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
 && rm -rf /var/lib/apt/lists/*

# ── Julia 1.11 ────────────────────────────────────────────────────────────────
ARG JULIA_VERSION=1.11.4
RUN wget -q https://julialang-s3.julialang.org/bin/linux/x64/1.11/julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && tar -xzf julia-${JULIA_VERSION}-linux-x86_64.tar.gz -C /usr/local --strip-components=1 \
 && rm julia-${JULIA_VERSION}-linux-x86_64.tar.gz

# ── Julia environment ────────────────────────────────────────────────────────
# Fixed depot path (not ~/.julia) so it's reliable across container restarts.
ENV JULIA_DEPOT_PATH=/opt/julia-depot

# Multi-target CPU codegen: the build host (GitHub Actions) likely differs from
# Fargate hardware.  Without this Julia precompiles only for the build CPU and
# the cache is invalidated at runtime on a different µarch → full recompile.
ENV JULIA_CPU_TARGET="generic;sandybridge,-xsaveopt,clone_all;haswell,clone_all"

# Disable native shared-library package images (.so) to avoid linker issues in
# Docker slim images.  Classic .ji precompile caches are portable and load in
# ~20-30 s — well within Fargate startup limits.
ENV JULIA_PKG_DISABLE_PKGIMAGES=true

# ── Pre-install Julia packages (cached layer) ────────────────────────────────
COPY install_julia_deps.jl /tmp/install_julia_deps.jl
RUN julia /tmp/install_julia_deps.jl

# ── Python deps ───────────────────────────────────────────────────────────────
COPY requirements.txt .
RUN python -m pip install --upgrade pip \
 && python -m pip install -r requirements.txt

# ── App code ──────────────────────────────────────────────────────────────────
COPY . .

# Verify precompile cache survives COPY (catches stale-cache issues at build
# time rather than at runtime).
RUN julia -e 'using KomaMRI, NPZ, JSON, HDF5, CUDA; println("Post-COPY precompile OK")'

# matplotlib & fontconfig scratch dirs (writable in Fargate /tmp)
RUN mkdir -p /tmp/.matplotlib /tmp/.fontconfig && chmod 777 /tmp/.matplotlib /tmp/.fontconfig
ENV MPLCONFIGDIR=/tmp/.matplotlib
ENV FONTCONFIG_PATH=/tmp/.fontconfig
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

# Fargate entrypoint — reads FILE_EVENT env var
ENTRYPOINT ["python", "app.py"]
