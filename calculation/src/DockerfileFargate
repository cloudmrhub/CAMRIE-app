# ==============================================================================
#  CAMRIE CPU image
#  Python 3.11 + Julia 1.12 + KomaMRI sysimage
#  Used by AWS Batch on Fargate Spot.
# ==============================================================================
FROM python:3.11-slim AS julia-builder

WORKDIR /build

# -- OS deps needed while compiling the Julia sysimage -------------------------
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential git ca-certificates wget curl libgomp1 \
 && rm -rf /var/lib/apt/lists/*

# -- Julia 1.12 ---------------------------------------------------------------
ARG JULIA_VERSION=1.12.6
RUN mkdir -p /opt/julia \
 && wget -q https://julialang-s3.julialang.org/bin/linux/x64/1.12/julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && tar -xzf julia-${JULIA_VERSION}-linux-x86_64.tar.gz -C /opt/julia --strip-components=1 \
 && rm julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && ln -s /opt/julia/bin/julia /usr/local/bin/julia

ENV JULIA_DEPOT_PATH=/opt/julia-depot
ENV JULIA_CPU_TARGET=generic
ENV JULIA_NUM_PRECOMPILE_TASKS=8
ENV JULIA_PKG_DISABLE_PKGIMAGES=true
ENV CAMRIE_JULIA_PROJECT=/opt/camrie-julia
ENV JULIA_PROJECT=/opt/camrie-julia
ARG CAMRIE_TOOLS_REF=v1

# -- Julia packages and sysimage ---------------------------------------------
RUN pip install --upgrade pip \
 && pip install "camrie-tools @ git+https://github.com/cloudmrhub/camrie-tools.git@${CAMRIE_TOOLS_REF}" \
 && camrie-install-julia --cpu --update --project-dir /opt/camrie-julia --install-dir /opt/julia-depot

RUN julia -e 'import Pkg; Pkg.add("PackageCompiler"); Pkg.precompile()'
COPY precompile_workload.jl /tmp/precompile_workload.jl
RUN julia -e 'using PackageCompiler; create_sysimage([:KomaInterface]; sysimage_path="/opt/julia-depot/komamri-sysimage.so", precompile_execution_file="/tmp/precompile_workload.jl", include_transitive_dependencies=true)'

# ==============================================================================
#  Final runtime image
# ==============================================================================
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        git ca-certificates curl libgomp1 \
 && rm -rf /var/lib/apt/lists/*

COPY --from=julia-builder /opt/julia /opt/julia
COPY --from=julia-builder /opt/julia-depot /opt/julia-depot
COPY --from=julia-builder /opt/camrie-julia /opt/camrie-julia

ENV JULIA_DEPOT_PATH=/opt/julia-depot
ENV JULIA_CPU_TARGET=generic
ENV JULIA_PKG_DISABLE_PKGIMAGES=true
ENV CAMRIE_JULIA_SYSIMAGE=/opt/julia-depot/komamri-sysimage.so
ENV CAMRIE_JULIA_PROJECT=/opt/camrie-julia
ENV JULIA_PROJECT=/opt/camrie-julia
ARG CAMRIE_TOOLS_REF=v1
ENV CAMRIE_TOOLS_REF=${CAMRIE_TOOLS_REF}
ENV PATH=/usr/local/bin:/opt/julia/bin:$PATH

# Production code invokes "julia" directly. Keep that interface and inject the
# sysimage here so every runtime Julia process benefits automatically.
RUN printf '%s\n' \
      '#!/bin/sh' \
      'if [ "${CAMRIE_DISABLE_JULIA_SYSIMAGE:-0}" = "1" ]; then' \
      '  exec /opt/julia/bin/julia --project=/opt/camrie-julia --pkgimages=no "$@"' \
      'fi' \
      'exec /opt/julia/bin/julia --project=/opt/camrie-julia --pkgimages=no --sysimage=/opt/julia-depot/komamri-sysimage.so --sysimage-native-code=no "$@"' \
      > /usr/local/bin/julia \
 && chmod +x /usr/local/bin/julia \
 && ln -s /usr/local/bin/julia /usr/local/bin/julia-fast

COPY requirements.txt .
RUN pip install --upgrade pip \
 && pip install -r requirements.txt \
 && pip install "camrie-tools @ git+https://github.com/cloudmrhub/camrie-tools.git@${CAMRIE_TOOLS_REF}"

COPY . .

RUN julia -e 'using KomaInterface; println("CPU Julia project: ", Base.active_project()); println("CPU sysimage OK")'

RUN mkdir -p /tmp/.matplotlib /tmp/.fontconfig && chmod 777 /tmp/.matplotlib /tmp/.fontconfig
ENV MPLCONFIGDIR=/tmp/.matplotlib
ENV FONTCONFIG_PATH=/tmp/.fontconfig
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt

ENTRYPOINT ["python", "app.py"]
