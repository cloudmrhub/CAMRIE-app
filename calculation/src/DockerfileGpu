# ==============================================================================
#  CAMRIE GPU image
#  CUDA 12.6 + Python 3.11 + Julia 1.12 + KomaMRI/CUDA sysimage
#  Used by AWS Batch on EC2 GPU Spot.
# ==============================================================================
FROM nvidia/cuda:12.6.3-devel-ubuntu22.04 AS julia-builder

WORKDIR /build

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential git ca-certificates wget curl libgomp1 \
        python3 python3-pip \
 && rm -rf /var/lib/apt/lists/*

ARG JULIA_VERSION=1.12.6
RUN mkdir -p /opt/julia \
 && wget -q https://julialang-s3.julialang.org/bin/linux/x64/1.12/julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && tar -xzf julia-${JULIA_VERSION}-linux-x86_64.tar.gz -C /opt/julia --strip-components=1 \
 && rm julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && ln -s /opt/julia/bin/julia /usr/local/bin/julia

ENV JULIA_DEPOT_PATH=/opt/julia-depot
ENV JULIA_CPU_TARGET=generic
ENV JULIA_NUM_PRECOMPILE_TASKS=8
ENV JULIA_CUDA_USE_BINARYBUILDER=true
ENV CAMRIE_JULIA_PROJECT=/opt/camrie-julia
ENV JULIA_PROJECT=/opt/camrie-julia
ARG CAMRIE_TOOLS_REF=v1

RUN python3 -m pip install --upgrade pip \
 && python3 -m pip install "camrie-tools @ git+https://github.com/cloudmrhub/camrie-tools.git@${CAMRIE_TOOLS_REF}" \
 && camrie-install-julia --update --project-dir /opt/camrie-julia --install-dir /opt/julia-depot

RUN julia -e 'import Pkg; Pkg.add("PackageCompiler"); Pkg.precompile()'
COPY precompile_workload_gpu.jl /tmp/precompile_workload_gpu.jl
RUN julia -e 'using PackageCompiler; create_sysimage([:KomaInterface, :CUDA]; sysimage_path="/opt/julia-depot/komamri-gpu-sysimage.so", precompile_execution_file="/tmp/precompile_workload_gpu.jl", include_transitive_dependencies=true)'

# ==============================================================================
#  Final runtime image
# ==============================================================================
FROM nvidia/cuda:12.6.3-runtime-ubuntu22.04

WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        software-properties-common \
 && add-apt-repository ppa:deadsnakes/ppa \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev python3-pip \
        git ca-certificates curl libgomp1 \
 && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
 && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
 && rm -rf /var/lib/apt/lists/*

COPY --from=julia-builder /opt/julia /opt/julia
COPY --from=julia-builder /opt/julia-depot /opt/julia-depot
COPY --from=julia-builder /opt/camrie-julia /opt/camrie-julia

ENV JULIA_DEPOT_PATH=/opt/julia-depot
ENV JULIA_CPU_TARGET=generic
ENV JULIA_CUDA_USE_BINARYBUILDER=true
ENV CAMRIE_JULIA_SYSIMAGE=/opt/julia-depot/komamri-gpu-sysimage.so
ENV CAMRIE_JULIA_PROJECT=/opt/camrie-julia
ENV JULIA_PROJECT=/opt/camrie-julia
ARG CAMRIE_TOOLS_REF=v1
ENV CAMRIE_TOOLS_REF=${CAMRIE_TOOLS_REF}
ENV PATH=/usr/local/bin:/opt/julia/bin:$PATH

RUN printf '%s\n' \
      '#!/bin/sh' \
      'if [ "${CAMRIE_DISABLE_JULIA_SYSIMAGE:-0}" = "1" ]; then' \
      '  exec /opt/julia/bin/julia --project=/opt/camrie-julia --pkgimages=no "$@"' \
      'fi' \
      'exec /opt/julia/bin/julia --project=/opt/camrie-julia --pkgimages=no --sysimage=/opt/julia-depot/komamri-gpu-sysimage.so --sysimage-native-code=no "$@"' \
      > /usr/local/bin/julia \
 && chmod +x /usr/local/bin/julia \
 && ln -s /usr/local/bin/julia /usr/local/bin/julia-fast

COPY requirements.txt .
RUN python3 -m pip install --upgrade pip \
 && python -m pip install -r requirements.txt \
 && python3 -m pip install "camrie-tools @ git+https://github.com/cloudmrhub/camrie-tools.git@${CAMRIE_TOOLS_REF}"

COPY . .

RUN julia -e 'using KomaInterface, CUDA; println("GPU Julia project: ", Base.active_project()); println("GPU sysimage OK")'

RUN mkdir -p /tmp/.matplotlib /tmp/.fontconfig && chmod 777 /tmp/.matplotlib /tmp/.fontconfig
ENV MPLCONFIGDIR=/tmp/.matplotlib
ENV FONTCONFIG_PATH=/tmp/.fontconfig
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV NVIDIA_VISIBLE_DEVICES=all

ENTRYPOINT ["python", "app.py"]
