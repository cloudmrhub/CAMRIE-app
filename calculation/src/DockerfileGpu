# ==============================================================================
#  CAMRIE GPU image
#  CUDA 12.6 + Python 3.11 + Julia 1.11 + KomaMRI/CUDA sysimage
#  Used by AWS Batch on EC2 GPU Spot.
# ==============================================================================
FROM nvidia/cuda:12.6.3-devel-ubuntu22.04 AS julia-builder

WORKDIR /build

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        build-essential git ca-certificates wget curl libgomp1 \
 && rm -rf /var/lib/apt/lists/*

ARG JULIA_VERSION=1.11.4
RUN mkdir -p /opt/julia \
 && wget -q https://julialang-s3.julialang.org/bin/linux/x64/1.11/julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && tar -xzf julia-${JULIA_VERSION}-linux-x86_64.tar.gz -C /opt/julia --strip-components=1 \
 && rm julia-${JULIA_VERSION}-linux-x86_64.tar.gz \
 && ln -s /opt/julia/bin/julia /usr/local/bin/julia

ENV JULIA_DEPOT_PATH=/opt/julia-depot
ENV JULIA_CPU_TARGET=generic
ENV JULIA_NUM_PRECOMPILE_TASKS=8
ENV JULIA_CUDA_USE_BINARYBUILDER=true

COPY install_julia_deps_gpu.jl /tmp/install_julia_deps_gpu.jl
RUN julia /tmp/install_julia_deps_gpu.jl

RUN julia -e 'import Pkg; Pkg.add("PackageCompiler"); Pkg.precompile()'
COPY precompile_workload_gpu.jl /tmp/precompile_workload_gpu.jl
RUN julia -e 'using PackageCompiler; create_sysimage([:KomaMRI, :CUDA, :NPZ, :JSON, :HDF5, :LinearAlgebra]; sysimage_path="/opt/julia-depot/komamri-gpu-sysimage.so", precompile_execution_file="/tmp/precompile_workload_gpu.jl")'

# ==============================================================================
#  Final runtime image
# ==============================================================================
FROM nvidia/cuda:12.6.3-runtime-ubuntu22.04

WORKDIR /app

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Etc/UTC
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        software-properties-common \
 && add-apt-repository ppa:deadsnakes/ppa \
 && apt-get update \
 && apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3.11-dev python3-pip \
        git ca-certificates curl libgomp1 \
 && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1 \
 && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
 && rm -rf /var/lib/apt/lists/*

COPY --from=julia-builder /opt/julia /opt/julia
COPY --from=julia-builder /opt/julia-depot /opt/julia-depot

ENV JULIA_DEPOT_PATH=/opt/julia-depot
ENV JULIA_CPU_TARGET=generic
ENV JULIA_CUDA_USE_BINARYBUILDER=true
ENV CAMRIE_JULIA_SYSIMAGE=/opt/julia-depot/komamri-gpu-sysimage.so
ENV PATH=/usr/local/bin:/opt/julia/bin:$PATH

RUN printf '%s\n' \
      '#!/bin/sh' \
      'exec /opt/julia/bin/julia --sysimage=/opt/julia-depot/komamri-gpu-sysimage.so "$@"' \
      > /usr/local/bin/julia \
 && chmod +x /usr/local/bin/julia \
 && ln -s /usr/local/bin/julia /usr/local/bin/julia-fast

COPY requirements.txt .
RUN python -m pip install --upgrade pip \
 && python -m pip install -r requirements.txt

COPY . .

RUN julia -e 'using KomaMRI, NPZ, JSON, HDF5, CUDA; println("GPU sysimage OK")'

RUN mkdir -p /tmp/.matplotlib /tmp/.fontconfig && chmod 777 /tmp/.matplotlib /tmp/.fontconfig
ENV MPLCONFIGDIR=/tmp/.matplotlib
ENV FONTCONFIG_PATH=/tmp/.fontconfig
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
ENV NVIDIA_VISIBLE_DEVICES=all

ENTRYPOINT ["python", "app.py"]
