		{
			"name": "3 – Queue CAMRIE Job",
			"item": [
				{
					"name": "3.1 Queue Job",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const resp = pm.response.json();",
									"if (resp.pipeline) {",
									"    pm.collectionVariables.set('pipeline_id', resp.pipeline);",
									"    pm.test('Job queued', () => pm.expect(resp.executionArn).to.be.a('string'));",
									"} else {",
									"    pm.test('Queue failed', () => pm.expect.fail(JSON.stringify(resp)));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"cloudapp_name\": \"CAMRIE\",\n    \"alias\": \"Postman Test – Cylindrical Phantom\",\n    \"mode\": \"mode_1\",\n    \"task\": {\n        \"options\": {\n            \"rho\": {\n                \"type\": \"s3\",\n                \"bucket\": \"{{data_bucket}}\",\n                \"key\": \"{{rho_s3_key}}\",\n                \"filename\": \"rho.nii\"\n            },\n            \"t1\": {\n                \"type\": \"s3\",\n                \"bucket\": \"{{data_bucket}}\",\n                \"key\": \"{{t1_s3_key}}\",\n                \"filename\": \"t1.nii\"\n            },\n            \"t2\": {\n                \"type\": \"s3\",\n                \"bucket\": \"{{data_bucket}}\",\n                \"key\": \"{{t2_s3_key}}\",\n                \"filename\": \"t2.nii\"\n            },\n            \"sequence\": {\n                \"type\": \"s3\",\n                \"bucket\": \"{{data_bucket}}\",\n                \"key\": \"{{seq_s3_key}}\",\n                \"filename\": \"T1w_TSE.seq\"\n            },\n            \"geometry\": {\n                \"isocenter_mm\": null,\n                \"slice_normal\": [0, 0, 1],\n                \"num_slices\": 4,\n                \"slice_thickness_mm\": null,\n                \"slice_gap_mm\": 0.0\n            },\n            \"simulation\": {\n                \"b0\": 1.5,\n                \"spin_factor\": 4,\n                \"n_threads\": 4,\n                \"use_gpu\": false,\n                \"apply_hamming\": true,\n                \"spins_per_voxel\": 1,\n                \"parallel_slices\": 1,\n                \"slice_padding\": 0.5\n            }\n        }\n    },\n    \"output\": null,\n    \"computing_unit_id\": null\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{api_base}}/pipeline/queue_job",
							"host": ["{{api_base}}"],
							"path": ["pipeline", "queue_job"]
						},
						"description": "Submit a CAMRIE simulation job.\n\nThe S3 keys are auto-filled from the upload steps. Adjust `geometry` and `simulation` parameters as needed.\n\n**Key simulation parameters:**\n- `b0`: Main field strength (T)\n- `spin_factor`: Spin density multiplier\n- `spins_per_voxel`: Spins per voxel for GRE\n- `parallel_slices`: Number of slices simulated in parallel\n- `slice_padding`: Padding factor for slice profile\n- `use_gpu`: Enable GPU acceleration (Fargate must have GPU)\n- `n_threads`: Julia threads"
					}
				}
			]
		},
