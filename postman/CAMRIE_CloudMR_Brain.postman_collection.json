	"item": [
		{
			"name": "1 – Authentication",
			"item": [
				{
					"name": "1.1 Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const resp = pm.response.json();",
									"if (resp.id_token) {",
									"    pm.collectionVariables.set('id_token', resp.id_token);",
									"    pm.collectionVariables.set('user_id', resp.user_id);",
									"    pm.test('Login successful – token saved', () => pm.expect(resp.id_token).to.be.a('string'));",
									"} else {",
									"    pm.test('Login failed', () => pm.expect.fail(JSON.stringify(resp)));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"{{email}}\",\n    \"password\": \"{{password}}\"\n}"
						},
						"url": {
							"raw": "{{api_base}}/auth/login",
							"host": ["{{api_base}}"],
							"path": ["auth", "login"]
						},
						"description": "Authenticate with CloudMR Brain (Cognito). Saves `id_token` and `user_id` as collection variables."
					}
				},
				{
					"name": "1.2 Get Profile",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{api_base}}/auth/profile",
							"host": ["{{api_base}}"],
							"path": ["auth", "profile"]
						},
						"description": "Verify the token works by fetching the user profile."
					}
				}
			]
		},
		{
			"name": "2 – Upload Files",
			"description": "Upload tissue maps (rho, t1, t2) and pulse sequence to S3 via multipart upload.\n\nFor each file:\n1. **Initiate** → get presigned part URLs and upload ID\n2. **PUT** each part to the presigned URL (collect ETag)\n3. **Finalize** → complete the multipart upload\n\nFor small files (<10 MB) there is only 1 part URL.",
			"item": [
				{
					"name": "2.1a Initiate Upload – rho.nii",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const resp = pm.response.json();",
									"if (resp.Key) {",
									"    pm.collectionVariables.set('rho_s3_key', resp.Key);",
									"    pm.collectionVariables.set('rho_upload_id', resp.uploadId);",
									"    if (resp.partUrls && resp.partUrls.length > 0) {",
									"        pm.collectionVariables.set('rho_part_url', resp.partUrls[0]);",
									"    }",
									"    pm.test('rho upload initiated', () => pm.expect(resp.Key).to.include('rho'));",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"filename\": \"rho.nii\",\n    \"filetype\": \"application/octet-stream\",\n    \"filesize\": 0,\n    \"filemd5\": \"\",\n    \"cloudapp_name\": \"CAMRIE\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{api_base}}/upload_initiate",
							"host": ["{{api_base}}"],
							"path": ["upload_initiate"]
						},
						"description": "Initiate multipart upload for rho.nii.\n\n**Important**: Set `filesize` to the actual file size in bytes. Set `filemd5` to the file's MD5 hex digest."
					}
				},
				{
					"name": "2.1b PUT Part – rho.nii",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "PUT",
						"header": [],
						"body": {
							"mode": "file",
							"file": {
								"src": ""
							}
						},
						"url": {
							"raw": "{{rho_part_url}}",
							"host": ["{{rho_part_url}}"]
						},
						"description": "Upload the file binary to the presigned S3 part URL.\n\n1. Select the rho.nii file in the Body → binary tab\n2. Send the request\n3. Copy the `ETag` header from the response for the finalize step"
					}
				},
				{
					"name": "2.1c Finalize Upload – rho.nii",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"uploadId\": \"{{rho_upload_id}}\",\n    \"Key\": \"{{rho_s3_key}}\",\n    \"parts\": [\n        {\n            \"partNumber\": 1,\n            \"etag\": \"PASTE_ETAG_FROM_PUT_RESPONSE\"\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{api_base}}/upload_finalize",
							"host": ["{{api_base}}"],
							"path": ["upload_finalize"]
						},
						"description": "Finalize the multipart upload. Replace `PASTE_ETAG_FROM_PUT_RESPONSE` with the actual ETag from step 2.1b."
					}
				},
